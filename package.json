{
  "name": "opencode-hexz",
  "version": "1.4.0",
  "description": "HEXZ — OpenCode upgrade layer. Anti-slop, security scanning, design scaffolds, web search, image handling, plugin marketplace.",
  "type": "module",
  "main": "dist/hexz.js",
  "exports": {
    ".": "./dist/hexz.js"
  },
  "scripts": {
    "build": "bun build src/hexz.ts --outfile dist/hexz.js --external bun",
    "typecheck": "tsc --noEmit",
    "test": "bun test",
    "dev": "bun run build --watch",
    "prepublishOnly": "bun run build",
    "lint": "biome check src/",
    "format": "biome format --write src/"
  },
  "files": [
    "dist",
    "README.md",
    "CONTRIBUTING.md"
  ],
  "keywords": [
    "opencode",
    "opencode-plugin",
    "hexz",
    "ai",
    "security",
    "design",
    "anti-slop"
  ],
  "license": "MIT",
  "engines": {
    "bun": ">=1.0.0"
  },
  "peerDependencies": {
    "@opencode-ai/plugin": "*"
  },
  "devDependencies": {
    "@types/bun": "^1.3.14",
    "@opencode-ai/plugin": "^1.17.7",
    "@biomejs/biome": "^1.9.0"
  }
}
